@model MedicalRecordsManager.Models.ApplicationUser
@{
    ViewData["Title"] = "Edit User";
}

<div class="card shadow-sm border-0 rounded-3" style="max-width:650px;">
    <div class="card-header text-white fw-bold py-3" style="background:#006064;">
        <i class="fas fa-user-edit me-2"></i> Edit User
    </div>
    <div class="card-body p-4">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Full Name *</label>
                    <input asp-for="FullName" class="form-control" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Email</label>
                    <input asp-for="Email" class="form-control" readonly
                           style="background:#f8f9fa;" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Role</label>
                    <select asp-for="UserRole" class="form-select">
                        <option value="Admin">Admin</option>
                        <option value="Doctor">Doctor</option>
                        <option value="Nurse">Nurse</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Department</label>
                    <input asp-for="Department" class="form-control"
                           placeholder="e.g. OPD, ICU" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Specialization</label>
                    <input asp-for="Specialization" class="form-control"
                           placeholder="Doctors only" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">New Password</label>
                    <input type="password" name="NewPassword" class="form-control"
                           placeholder="Leave blank to keep current" />
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn text-white px-4" style="background:#009688;">
                    <i class="fas fa-save me-1"></i> Save Changes
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary px-4">
                    <i class="fas fa-times me-1"></i> Cancel
                </a>
            </div>
        </form>
    </div>
</div>