@model IEnumerable<MedicalRecordsManager.Models.ApplicationUser>
@{
    ViewData["Title"] = "Manage Users";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h6 class="text-muted mb-0">All System Users</h6>
    <a asp-action="Create" class="btn text-white" style="background:#009688;">
        <i class="fas fa-user-plus me-1"></i> Add New User
    </a>
</div>

<div class="card shadow-sm border-0 rounded-3">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead style="background:#006064; color:white;">
                <tr>
                    <th>Full Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Specialization</th>
                    <th>Department</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model)
                {
                    <tr>
                        <td class="fw-semibold">
                            <i class="fas fa-user-circle me-2 text-muted"></i>@u.FullName
                        </td>
                        <td>@u.Email</td>
                        <td>
                            <span class="badge"
                                  style="background:@(u.UserRole == "Admin"  ? "#B71C1C" :
                                                                                        u.UserRole == "Doctor" ? "#1565C0" : "#2E7D32")">
                                @u.UserRole
                            </span>
                        </td>
                        <td>@(u.Specialization ?? "—")</td>
                        <td>@(u.Department ?? "—")</td>
                        <td>
                            <span class="badge"
                                  style="background:@(u.IsActive ? "#2E7D32" : "#B71C1C")">
                                @(u.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@u.Id"
                               class="btn btn-sm btn-outline-warning">
                                <i class="fas fa-edit"></i> Edit
                            </a>
                            @if (u.Email != User.Identity!.Name)
                            {
                                <form asp-action="ToggleStatus" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@u.Id" />
                                    <button type="submit"
                                            class="btn btn-sm @(u.IsActive ? "btn-outline-danger" : "btn-outline-success")"
                                            onclick="return confirm('@(u.IsActive ? "Deactivate" : "Activate") this user?')">
                                        <i class="fas fa-@(u.IsActive ? "ban" : "check")"></i>
                                        @(u.IsActive ? "Deactivate" : "Activate")
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">
                            <i class="fas fa-users-slash me-2"></i>No users found
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>