@{
    ViewData["Title"] = "Forbidden";
}

<div class="container d-flex justify-content-center align-items-center" style="height:70vh;">
    <div class="text-center">

        <div style="font-size:80px; color:#dc3545;">
            <i class="fas fa-user-lock"></i>
        </div>

        <h1 class="fw-bold mt-3" style="color:#006064;">
            403 - Forbidden
        </h1>

        <p class="text-muted fs-5 mt-3">
            You do not have permission to access this section of the Medical Records System.
        </p>

        <p class="text-muted">
            Please contact the system administrator if you believe this is an error.
        </p>

        <div class="mt-4">

            <a asp-controller="Home" asp-action="Index"
               class="btn text-white px-4"
               style="background:#009688;">
                <i class="fas fa-home me-2"></i>
                Return to Dashboard
            </a>

            <a asp-controller="Account" asp-action="Logout"
               class="btn btn-outline-secondary px-4 ms-2">
                <i class="fas fa-sign-out-alt me-2"></i>
                Logout
            </a>

        </div>

    </div>
</div>