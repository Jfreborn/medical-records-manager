@{
}
@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Login - Medical Records Manager</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
</head>
<body style="background: linear-gradient(135deg, #006064, #00897B); min-height:100vh;"
      class="d-flex align-items-center justify-content-center">

    <div class="card shadow-lg border-0 rounded-4" style="width:420px;">
        <div class="card-body p-5">

            <div class="text-center mb-4">
                <i class="fas fa-heartbeat fa-3x mb-2" style="color:#009688;"></i>
                <h4 class="fw-bold" style="color:#006064;">Medical Records Manager</h4>
                <p class="text-muted small">Sign in to your account</p>
            </div>

            @if (ViewData["Error"] != null)
            {
                <div class="alert alert-danger">
                    <i class="fas fa-exclamation-circle me-2"></i>@ViewData["Error"]
                </div>
            }

            <form method="post" asp-controller="Account" asp-action="Login">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

                <div class="mb-3">
                    <label class="form-label fw-semibold">Email Address</label>
                    <input type="email" name="email" class="form-control form-control-lg"
                           placeholder="you@hospital.com" required />
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold">Password</label>
                    <input type="password" name="password" class="form-control form-control-lg"
                           placeholder="Enter password" required />
                </div>

                <div class="mb-3 form-check">
                    <input type="checkbox" name="rememberMe" class="form-check-input" id="rememberMe" />
                    <label class="form-check-label" for="rememberMe">Remember me</label>
                </div>

                <button type="submit" class="btn w-100 btn-lg text-white fw-bold"
                        style="background:#009688;">
                    <i class="fas fa-sign-in-alt me-2"></i>Sign In
                </button>
            </form>

            <div class="text-center mt-4 text-muted small">
                <p class="mb-1">Default Admin: admin@hospital.com</p>
                <p class="mb-0">Password: Admin@12345</p>
            </div>
        </div>
    </div>

</body>
</html>