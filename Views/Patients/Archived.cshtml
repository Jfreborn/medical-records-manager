@model IEnumerable<MedicalRecordsManager.Models.Patient>

@{
    ViewData["Title"] = "Archived Patients";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <form class="d-flex gap-2">
        <input name="search"
               class="form-control"
               style="width:280px;"
               placeholder="Search name, number, phone..."
               value="@ViewBag.Search" />

        ```
        <button type="submit" class="btn text-white" style="background:#009688;">
            <i class="fas fa-search me-1"></i> Search
        </button>
    </form>
    ```

</div>

<div class="card shadow-sm border-0 rounded-3">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">

            ```
            <thead style="background:#006064; color:white;">
                <tr>
                    <th>Patient No.</th>
                    <th>Name</th>
                    <th>Gender</th>
                    <th>Blood Group</th>
                    <th>Phone</th>
                    <th>Registered</th>
                    <th>Status</th>
                    <th>Deleted At</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var p in Model)
                {
                    <tr>

                        <td>
                            <span class="badge text-white" style="background:#009688;">
                                @p.PatientNumber
                            </span>
                        </td>

                        <td class="fw-semibold">@p.FullName</td>

                        <td>@p.Gender</td>

                        <td>@p.BloodGroup</td>

                        <td>@p.PhoneNumber</td>

                        <td>@p.RegisteredAt.ToString("dd MMM yyyy")</td>

                        <td>
                            @if (p.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Inactive</span>
                            }
                        </td>

                        <td>
                            @(p.DeletedAt?.ToString("dd MMM yyyy"))
                        </td>

                        <td>

                            <a asp-action="Details"
                               asp-route-id="@p.Id"
                               class="btn btn-sm btn-outline-info">
                                <i class="fas fa-eye"></i> View
                            </a>

                            <a asp-action="Edit"
                               asp-route-id="@p.Id"
                               class="btn btn-sm btn-outline-warning">
                                <i class="fas fa-edit"></i> Edit
                            </a>

                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Restore"
                                   asp-route-id="@p.Id"
                                   class="btn btn-sm btn-success"
                                   onclick="return confirm('Restore this patient?')">
                                    <i class="fas fa-undo"></i> Restore
                                </a>
                            }

                        </td>

                    </tr>
                }

                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="9" class="text-center text-muted py-4">
                            <i class="fas fa-user-slash me-2"></i> No archived patients found
                        </td>
                    </tr>
                }

            </tbody>

        </table>
    </div>
    ```

</div>
