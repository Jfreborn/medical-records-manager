@model IEnumerable<MedicalRecordsManager.Models.MedicalRecord>
@{
    ViewData["Title"] = "Medical Records";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h6 class="text-muted mb-0">All Medical Records</h6>
    @if (User.IsInRole("Admin") || User.IsInRole("Doctor"))
    {
        <a asp-action="Create" class="btn text-white" style="background:#009688;">
            <i class="fas fa-plus me-1"></i> New Record
        </a>
    }
</div>

<div class="card shadow-sm border-0 rounded-3">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead style="background:#006064; color:white;">
                <tr>
                    <th>Date</th>
                    <th>Patient</th>
                    <th>Doctor</th>
                    <th>Diagnosis</th>
                    <th>Treatment</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td>@r.VisitDate.ToString("dd MMM yyyy")</td>
                        <td class="fw-semibold">@r.Patient.FullName</td>
                        <td>@r.Doctor.FullName</td>
                        <td>@r.Diagnosis</td>
                        <td>@r.Treatment</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@r.Id"
                               class="btn btn-sm btn-outline-info">
                                <i class="fas fa-eye"></i> View
                            </a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">
                            <i class="fas fa-file-medical me-2"></i>No medical records found
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>