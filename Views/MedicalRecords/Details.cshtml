@model MedicalRecordsManager.Models.MedicalRecord
@{ ViewData["Title"] = "Medical Record Details"; }

<div class="mb-3">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="fas fa-arrow-left me-1"></i> Back to Records
    </a>
</div>

<div class="row g-4">
    <!-- Main Record -->
    <div class="col-md-6">
        <div class="card border-0 shadow-sm rounded-3">
            <div class="card-header text-white fw-bold" style="background:#006064;">
                <i class="fas fa-file-medical me-2"></i> Visit Details
            </div>
            <div class="card-body p-4">
                <p><strong>Patient:</strong> @Model.Patient.FullName</p>
                <p><strong>Doctor:</strong> @Model.Doctor.FullName</p>
                <p><strong>Visit Date:</strong> @Model.VisitDate.ToString("dd MMM yyyy")</p>
                <hr/>
                <p><strong>Symptoms:</strong><br/>
                    <span class="text-muted">@Model.Symptoms</span></p>
                <p><strong>Diagnosis:</strong><br/>
                    <span class="text-muted">@Model.Diagnosis</span></p>
                <p><strong>Treatment:</strong><br/>
                    <span class="text-muted">@Model.Treatment</span></p>
                @if (!string.IsNullOrEmpty(Model.Notes))
                {
                    <p><strong>Notes:</strong><br/>
                        <span class="text-muted">@Model.Notes</span></p>
                }
            </div>
        </div>
    </div>

    <!-- Prescriptions -->
    <div class="col-md-6">
        <div class="card border-0 shadow-sm rounded-3 mb-3">
            <div class="card-header bg-white fw-bold">
                <i class="fas fa-pills me-2" style="color:#009688;"></i>
                Prescriptions (@Model.Prescriptions.Count)
            </div>
            <div class="table-responsive">
                <table class="table table-sm mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Medicine</th>
                            <th>Dosage</th>
                            <th>Frequency</th>
                            <th>Days</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model.Prescriptions)
                        {
                            <tr>
                                <td class="fw-semibold">@p.MedicineName</td>
                                <td>@p.Dosage</td>
                                <td>@p.Frequency</td>
                                <td>@p.DurationDays</td>
                            </tr>
                        }
                        @if (!Model.Prescriptions.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-muted text-center py-2">
                                    No prescriptions
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Lab Results -->
        <div class="card border-0 shadow-sm rounded-3">
            <div class="card-header bg-white fw-bold">
                <i class="fas fa-flask me-2" style="color:#009688;"></i>
                Lab Results (@Model.LabResults.Count)
            </div>
            <div class="table-responsive">
                <table class="table table-sm mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Test</th>
                            <th>Result</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var l in Model.LabResults)
                        {
                            <tr>
                                <td class="fw-semibold">@l.TestName</td>
                                <td>@l.Result</td>
                                <td>
                                    <span class="badge"
                                          style="background:@(l.Status == "Ready" ? "#2E7D32" : "#E65100")">
                                        @l.Status
                                    </span>
                                </td>
                            </tr>
                        }
                        @if (!Model.LabResults.Any())
                        {
                            <tr>
                                <td colspan="3" class="text-muted text-center py-2">
                                    No lab results
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>