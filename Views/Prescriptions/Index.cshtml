@model IEnumerable<MedicalRecordsManager.Models.Prescriptions>
@{
    ViewData["Title"] = "Prescriptions";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h6 class="text-muted mb-0">All Prescriptions</h6>
    @if (User.IsInRole("Admin") || User.IsInRole("Doctor"))
    {
        <a asp-action="Create" class="btn text-white" style="background:#009688;">
            <i class="fas fa-plus me-1"></i> New Prescription
        </a>
    }
</div>

<div class="card shadow-sm border-0 rounded-3">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead style="background:#006064; color:white;">
                <tr>
                    <th>Date</th>
                    <th>Patient</th>
                    <th>Doctor</th>
                    <th>Medicine</th>
                    <th>Dosage</th>
                    <th>Frequency</th>
                    <th>Duration</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td>@p.PrescribedAt.ToString("dd MMM yyyy")</td>
                        <td class="fw-semibold">@p.Patient.FullName</td>
                        <td>@p.Doctor.FullName</td>
                        <td>
                            <span class="badge text-white" style="background:#009688;">
                                @p.MedicineName
                            </span>
                        </td>
                        <td>@p.Dosage</td>
                        <td>@p.Frequency</td>
                        <td>@p.DurationDays days</td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">
                            <i class="fas fa-pills me-2"></i>No prescriptions found
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>